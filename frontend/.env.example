# Base URL for the OmniCloud backend API.
# Defaults to http://localhost:8787/api when unset.
VITE_API_BASE_URL=http://localhost:8787/api

# Optional explicit WebSocket base URL.
# When unset it is derived from VITE_API_BASE_URL (http -> ws, https -> wss).
VITE_WS_BASE_URL=ws://localhost:8787/ws/uploads